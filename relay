#!/bin/bash
# Agent Relay — secure messaging between AI agent instances.
# relay connect              → host, wait for peers
# relay connect name@user@host#key → join a host
# relay send peer "message"  → send a message

set -euo pipefail

RELAY_HOME="${AGENT_RELAY_HOME:-$HOME/.agent-relay}"
CONFIG="$RELAY_HOME/config.json"
IDENTITY_DIR="$RELAY_HOME/identity"
PEERS_DIR="$RELAY_HOME/peers"
MESSAGES="$RELAY_HOME/messages.jsonl"

# ── Helpers ─────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

ensure_init() {
  [ -f "$CONFIG" ] || die "Not initialized. Run: relay connect"
  [ -f "$IDENTITY_DIR/private.pem" ] || die "No keypair. Run: relay connect"
}

get_name() {
  python3 -c "import json; print(json.load(open('$CONFIG'))['name'])" 2>/dev/null || echo "unknown"
}

get_host() {
  local ts_bin=""
  if command -v tailscale >/dev/null 2>&1; then
    ts_bin="tailscale"
  elif [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ]; then
    ts_bin="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
  fi
  if [ -n "$ts_bin" ]; then
    local ts_ip
    ts_ip=$("$ts_bin" ip -4 2>/dev/null || true)
    [ -n "$ts_ip" ] && echo "$ts_ip" && return
  fi
  hostname
}

get_config_val() {
  python3 -c "import json; print(json.load(open('$CONFIG')).get('$1','$2'))" 2>/dev/null || echo "$2"
}

timestamp() { date -u +%Y-%m-%dT%H:%M:%SZ; }

sign_message() {
  local tmpfile; tmpfile=$(mktemp)
  printf '%s' "$1" > "$tmpfile"
  openssl pkeyutl -sign -inkey "$IDENTITY_DIR/private.pem" -in "$tmpfile" 2>/dev/null | base64
  rm -f "$tmpfile"
}

relay_ssh() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    ssh -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    ssh -o StrictHostKeyChecking=accept-new "$@"
  fi
}

relay_scp() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    scp -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    scp -o StrictHostKeyChecking=accept-new "$@"
  fi
}

ensure_sshd() {
  if relay_ssh -o ConnectTimeout=3 localhost "echo ok" 2>/dev/null; then
    return 0
  fi
  # Try passwordless sudo
  sudo -n launchctl kickstart -k system/com.openssh.sshd 2>/dev/null \
    || sudo -n /usr/sbin/sshd 2>/dev/null \
    || sudo -n systemctl start sshd 2>/dev/null \
    || true
  sleep 1
  if relay_ssh -o ConnectTimeout=3 localhost "echo ok" 2>/dev/null; then
    echo "  SSH started."
    return 0
  fi
  echo ""
  echo "  SSH is not working (required for hosting)."
  echo ""
  if [ "$(uname)" = "Darwin" ]; then
    echo "  Fix with ONE of:"
    echo "    sudo launchctl kickstart -k system/com.openssh.sshd"
    echo "    sudo /usr/sbin/sshd"
    echo "  Or: System Settings > General > Sharing > Remote Login (toggle OFF then ON if already on)"
  else
    echo "  Fix with: sudo systemctl start sshd"
  fi
  echo ""
  echo "  Then retry: relay connect"
  return 1
}

init_identity() {
  local name="$1"
  mkdir -p "$RELAY_HOME" "$IDENTITY_DIR" "$PEERS_DIR"
  if [ ! -f "$IDENTITY_DIR/private.pem" ]; then
    openssl genpkey -algorithm Ed25519 -out "$IDENTITY_DIR/private.pem" 2>/dev/null
    openssl pkey -in "$IDENTITY_DIR/private.pem" -pubout -out "$IDENTITY_DIR/public.pem" 2>/dev/null
    chmod 600 "$IDENTITY_DIR/private.pem"
  fi
  if [ ! -f "$IDENTITY_DIR/ssh_key" ]; then
    ssh-keygen -t ed25519 -f "$IDENTITY_DIR/ssh_key" -N "" -C "agent-relay-${name}" -q
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    local pubkey; pubkey=$(cat "$IDENTITY_DIR/ssh_key.pub")
    grep -qF "$pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
      echo "$pubkey" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
    }
  fi
  touch "$MESSAGES"
}

monitor() {
  # Runs in foreground — outputs new messages as they arrive
  local my_name host_target host_port last=0
  my_name=$(get_name)
  host_target=$(get_config_val host_target "")
  host_port=$(get_config_val host_port 22)

  while true; do
    local lines=""
    if [ -n "$host_target" ]; then
      lines=$(relay_ssh -p "$host_port" "$host_target" "tail -n +$((last+1)) ~/.agent-relay/messages.jsonl 2>/dev/null" 2>/dev/null) || true
    else
      lines=$(tail -n +$((last+1)) "$MESSAGES" 2>/dev/null) || true
    fi
    if [ -n "$lines" ]; then
      local count; count=$(echo "$lines" | wc -l)
      last=$((last + count))
      echo "$lines" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        local msg_from
        msg_from=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('from',''))" 2>/dev/null || true)
        [ "$msg_from" = "$my_name" ] && continue
        echo "$line"
      done
    fi
    sleep 5
  done
}

# ── Commands ────────────────────────────────────────────────────────────

cmd_connect() {
  local target="${1:-}"

  if [ -n "$target" ] && echo "$target" | grep -q '@'; then
    # ── JOIN MODE ──────────────────────────────────────────────────
    local host_ssh_pubkey_b64=""
    if echo "$target" | grep -q '#'; then
      host_ssh_pubkey_b64="${target##*#}"
      target="${target%%#*}"
    fi

    local peer_name ssh_target peer_port=22
    peer_name="${target%%@*}"
    ssh_target="${target#*@}"
    if echo "$ssh_target" | grep -q ':'; then
      peer_port="${ssh_target##*:}"
      ssh_target="${ssh_target%:*}"
    fi

    [ -z "$peer_name" ] || [ -z "$ssh_target" ] && die "Format: relay connect name@user@host#key"

    # Init
    local my_name
    my_name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)
    init_identity "$my_name"
    cat > "$CONFIG" << EOF
{
  "name": "$my_name",
  "host": "$(get_host)",
  "host_target": "$ssh_target",
  "host_port": $peer_port,
  "created": "$(timestamp)"
}
EOF

    # Authorize host's SSH pubkey
    if [ -n "$host_ssh_pubkey_b64" ]; then
      local host_ssh_pubkey
      host_ssh_pubkey=$(echo "$host_ssh_pubkey_b64" | base64 -d 2>/dev/null || echo "$host_ssh_pubkey_b64" | base64 -D 2>/dev/null || true)
      if [ -n "$host_ssh_pubkey" ]; then
        mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
        grep -qF "$host_ssh_pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
          echo "$host_ssh_pubkey" >> "$HOME/.ssh/authorized_keys"
          chmod 600 "$HOME/.ssh/authorized_keys"
        }
      fi
    fi

    # Register with host via SSH
    echo "  Connecting to $ssh_target:$peer_port..."
    local register_cmd="
      mkdir -p ~/.ssh && chmod 700 ~/.ssh
      KEY='$(cat "$IDENTITY_DIR/ssh_key.pub")'
      grep -qF \"\$KEY\" ~/.ssh/authorized_keys 2>/dev/null || echo \"\$KEY\" >> ~/.ssh/authorized_keys
      chmod 600 ~/.ssh/authorized_keys
      mkdir -p ~/.agent-relay/peers
      echo '{\"name\":\"${my_name}\",\"host\":\"$(whoami)@$(get_host)\",\"paired\":\"$(timestamp)\"}' > ~/.agent-relay/peers/${my_name}.json
      cat > ~/.agent-relay/peers/${my_name}.pub << SIGNKEY
$(cat "$IDENTITY_DIR/public.pem")
SIGNKEY
      echo 'OK'
    "

    # Try relay key + defaults, then tailscale ssh
    local ssh_output=""
    ssh_output=$(relay_ssh -p "$peer_port" "$ssh_target" "$register_cmd" 2>&1) || true
    if ! echo "$ssh_output" | grep -q 'OK'; then
      # Try tailscale ssh (auth via tailscale identity, no keys needed)
      local ts_bin=""
      command -v tailscale >/dev/null 2>&1 && ts_bin="tailscale"
      [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ] && ts_bin="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
      if [ -n "$ts_bin" ]; then
        local ts_host="${ssh_target##*@}"
        ssh_output=$($ts_bin ssh "$ssh_target" "$register_cmd" 2>&1) || true
      fi
    fi

    if echo "$ssh_output" | grep -q 'OK'; then
      echo "  Connected to '$peer_name'"
      echo "  Monitoring for messages..."
      monitor
    else
      echo ""
      echo "  Can't SSH to $ssh_target:$peer_port"
      echo ""
      echo "  $ssh_output"
      echo ""
      echo "  To fix, have the host authorize your key:"
      echo "    echo '$(cat "$IDENTITY_DIR/ssh_key.pub")' >> ~/.ssh/authorized_keys"
      echo ""
      echo "  Or enable Tailscale SSH on both machines."
      exit 1
    fi

  else
    # ── HOST MODE ─────────────────────────────────────────────────
    local name="${target:-}"
    [ -z "$name" ] && name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)

    init_identity "$name"

    if ensure_sshd; then
      cat > "$CONFIG" << EOF
{
  "name": "$name",
  "host": "$(get_host)",
  "created": "$(timestamp)"
}
EOF

      local ssh_pubkey_b64
      ssh_pubkey_b64=$(base64 < "$IDENTITY_DIR/ssh_key.pub" | tr -d '\n')
      local host; host=$(get_host)
      local user; user=$(whoami)

      echo ""
      echo "  Hosting as '$name'"
      echo ""
      echo "  On the other machine:"
      echo "    relay connect ${name}@${user}@${host}#${ssh_pubkey_b64}"
      echo ""
      echo "  Monitoring for messages..."
      monitor
    else
      # ensure_sshd already printed diagnostics and fix instructions
      exit 1
    fi
  fi
}

cmd_send() {
  local peer_name="${1:-}"
  shift 2>/dev/null || true
  local msg="$*"
  [ -z "$peer_name" ] || [ -z "$msg" ] && die "Usage: relay send <peer> <message>"
  ensure_init

  local my_name ts
  my_name=$(get_name)
  ts=$(timestamp)

  local escaped_msg
  escaped_msg=$(printf '%s' "$msg" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")

  local payload="{\"from\":\"$my_name\",\"to\":\"$peer_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\"}"
  local sig; sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"to\":\"$peer_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\",\"sig\":\"$sig\"}"

  local host_target host_port
  host_target=$(get_config_val host_target "")
  host_port=$(get_config_val host_port 22)

  if [ -n "$host_target" ]; then
    relay_ssh -p "$host_port" "$host_target" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null \
      || die "Failed to deliver to host ($host_target)"
  else
    echo "$full_msg" >> "$MESSAGES"
  fi
}

cmd_send_file() {
  local peer_name="${1:-}" filepath="${2:-}"
  [ -z "$peer_name" ] || [ -z "$filepath" ] && die "Usage: relay send-file <peer> <path>"
  [ -f "$filepath" ] || die "File not found: $filepath"
  ensure_init

  local host_target host_port my_name
  host_target=$(get_config_val host_target "")
  host_port=$(get_config_val host_port 22)
  my_name=$(get_name)

  local filename; filename=$(basename "$filepath")
  local target_host="$host_target"
  [ -z "$target_host" ] && target_host="localhost"

  relay_ssh -p "$host_port" "$target_host" "mkdir -p ~/.agent-relay/files/${my_name}" 2>/dev/null
  relay_scp -P "$host_port" -q "$filepath" "${target_host}:~/.agent-relay/files/${my_name}/${filename}" 2>/dev/null \
    || die "Failed to transfer $filename"

  local filesize; filesize=$(stat -f%z "$filepath" 2>/dev/null || stat -c%s "$filepath" 2>/dev/null || echo "0")
  cmd_send "$peer_name" "Sent file: $filename ($filesize bytes)"
  echo "Sent $filename ($filesize bytes)"
}

cmd_peers() {
  ensure_init
  local found=false
  for f in "$PEERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    found=true
    local name host
    name=$(python3 -c "import json; print(json.load(open('$f'))['name'])" 2>/dev/null)
    host=$(python3 -c "import json; print(json.load(open('$f'))['host'])" 2>/dev/null)
    echo "  $name → $host"
  done
  [ "$found" = false ] && echo "  No peers yet."
}

cmd_logs() {
  ensure_init
  local count="${1:-20}"
  local host_target host_port
  host_target=$(get_config_val host_target "")
  host_port=$(get_config_val host_port 22)

  local raw
  if [ -n "$host_target" ]; then
    raw=$(relay_ssh -p "$host_port" "$host_target" "tail -${count} ~/.agent-relay/messages.jsonl 2>/dev/null" 2>/dev/null) || true
  else
    raw=$(tail -"$count" "$MESSAGES" 2>/dev/null) || true
  fi
  echo "$raw" | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        m = json.loads(line.strip())
        print(f\"[{m.get('ts','')}] {m.get('from','?')}: {m.get('msg','')}\")
    except: pass
"
}

# ── Dispatch ────────────────────────────────────────────────────────────

case "${1:-help}" in
  connect|setup|start|join) shift; cmd_connect "$@" ;;
  send)      shift; cmd_send "$@" ;;
  send-file) shift; cmd_send_file "$@" ;;
  peers)     cmd_peers ;;
  logs)      shift; cmd_logs "$@" ;;
  monitor)   shift; monitor "$@" ;;
  help|--help|-h)
    echo "Agent Relay — secure messaging between AI agent instances"
    echo ""
    echo "  relay connect                        Host — wait for peers"
    echo "  relay connect <name@user@host#key>   Join a host"
    echo "  relay send <peer> <message>          Send a message"
    echo "  relay peers                          List connected peers"
    ;;
  *) die "Unknown command: $1. Try: relay help" ;;
esac
