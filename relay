#!/bin/bash
# Agent Relay — secure peer-to-peer messaging between AI agent instances.
# Two commands to connect: `relay start <name>` on one machine, `relay join <name@host>` on the other.

set -euo pipefail

RELAY_HOME="${AGENT_RELAY_HOME:-$HOME/.agent-relay}"
CONFIG="$RELAY_HOME/config.json"
IDENTITY_DIR="$RELAY_HOME/identity"
PEERS_DIR="$RELAY_HOME/peers"
MESSAGES="$RELAY_HOME/messages.jsonl"

# ── Helpers ─────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

ensure_init() {
  [ -f "$CONFIG" ] || die "Not initialized. Run: relay start <name>"
  [ -f "$IDENTITY_DIR/private.pem" ] || die "No keypair. Run: relay start <name>"
}

get_name() {
  python3 -c "import json; print(json.load(open('$CONFIG'))['name'])" 2>/dev/null || echo "unknown"
}

get_host() {
  # Prefer Tailscale IP (always reachable across tailnet), fall back to local hostname
  local ts_bin=""
  if command -v tailscale >/dev/null 2>&1; then
    ts_bin="tailscale"
  elif [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ]; then
    ts_bin="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
  fi
  if [ -n "$ts_bin" ]; then
    # Use IPv4 Tailscale address — works regardless of MagicDNS config
    local ts_ip
    ts_ip=$("$ts_bin" ip -4 2>/dev/null || true)
    [ -n "$ts_ip" ] && echo "$ts_ip" && return
  fi
  hostname
}

timestamp() { date -u +%Y-%m-%dT%H:%M:%SZ; }

sign_message() {
  local tmpfile
  tmpfile=$(mktemp)
  printf '%s' "$1" > "$tmpfile"
  openssl pkeyutl -sign -inkey "$IDENTITY_DIR/private.pem" -in "$tmpfile" 2>/dev/null | base64
  rm -f "$tmpfile"
}

PAIR_PORT=7547

cmd_listen() {
  # One-shot TCP listener for key exchange during pairing
  # Joiner connects, sends its SSH pubkey + signing pubkey as JSON
  # We reply with ours, then both sides authorize each other
  local my_ssh_pub my_sign_pub
  my_ssh_pub=$(cat "$IDENTITY_DIR/ssh_key.pub" 2>/dev/null)
  my_sign_pub=$(cat "$IDENTITY_DIR/public.pem" 2>/dev/null)
  local my_name
  my_name=$(get_name)
  local my_host
  my_host="$(whoami)@$(get_host)"

  # Use python3 for a simple one-shot TCP server
  python3 -c "
import socket, json, sys

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
sock.bind(('0.0.0.0', $PAIR_PORT))
sock.listen(1)
conn, addr = sock.accept()
data = b''
while True:
    chunk = conn.recv(4096)
    if not chunk: break
    data += chunk
    if b'\n' in data: break

# Parse joiner's info
joiner = json.loads(data.decode().strip())

# Send our info back
response = json.dumps({
    'name': '$my_name',
    'host': '$my_host',
    'ssh_pub': '''$my_ssh_pub''',
    'sign_pub': '''$my_sign_pub'''
})
conn.sendall((response + '\n').encode())
conn.close()
sock.close()

# Authorize joiner's SSH key
import os
ssh_dir = os.path.expanduser('~/.ssh')
os.makedirs(ssh_dir, mode=0o700, exist_ok=True)
ak = os.path.join(ssh_dir, 'authorized_keys')
ssh_key = joiner.get('ssh_pub', '')
if ssh_key:
    existing = open(ak).read() if os.path.exists(ak) else ''
    if ssh_key not in existing:
        with open(ak, 'a') as f:
            f.write(ssh_key + '\n')
        os.chmod(ak, 0o600)

# Save joiner as peer
peers_dir = os.path.expanduser('$PEERS_DIR')
os.makedirs(peers_dir, exist_ok=True)
jname = joiner['name']
with open(os.path.join(peers_dir, jname + '.pub'), 'w') as f:
    f.write(joiner.get('sign_pub', ''))
with open(os.path.join(peers_dir, jname + '.json'), 'w') as f:
    json.dump({'name': jname, 'host': joiner['host'], 'paired': '$(timestamp)'}, f, indent=2)

print(f'  Paired with {jname} ({joiner[\"host\"]})')
" || die "Listener failed"
}

relay_ssh() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    # Include relay key but allow default keys too (needed for initial join)
    ssh -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    ssh -o StrictHostKeyChecking=accept-new "$@"
  fi
}

relay_scp() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    scp -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    scp -o StrictHostKeyChecking=accept-new "$@"
  fi
}

# ── Commands ────────────────────────────────────────────────────────────

cmd_start() {
  local name="${1:-}"
  [ -z "$name" ] && die "Usage: relay start <your-name>"

  local PRIMARY_HOME="$HOME/.agent-relay"

  # If primary already exists with this name, auto-increment for a new session
  if [ -f "$PRIMARY_HOME/config.json" ]; then
    local existing_name
    existing_name=$(python3 -c "import json; print(json.load(open('$PRIMARY_HOME/config.json'))['name'])" 2>/dev/null)
    if [ "$existing_name" = "$name" ] || echo "$existing_name" | grep -qE "^${name}(-[0-9]+)?$"; then
      # Find next available number
      local n=1
      while [ -d "$HOME/.agent-relay-${name}-${n}" ]; do
        n=$((n + 1))
      done
      name="${name}-${n}"
      RELAY_HOME="$HOME/.agent-relay-${name}"
      CONFIG="$RELAY_HOME/config.json"
      IDENTITY_DIR="$RELAY_HOME/identity"
      PEERS_DIR="$RELAY_HOME/peers"
      MESSAGES="$RELAY_HOME/messages.jsonl"
    fi
  fi

  mkdir -p "$RELAY_HOME" "$IDENTITY_DIR" "$PEERS_DIR"

  # Generate Ed25519 signing keypair if needed
  if [ ! -f "$IDENTITY_DIR/private.pem" ]; then
    openssl genpkey -algorithm Ed25519 -out "$IDENTITY_DIR/private.pem" 2>/dev/null
    openssl pkey -in "$IDENTITY_DIR/private.pem" -pubout -out "$IDENTITY_DIR/public.pem" 2>/dev/null
    chmod 600 "$IDENTITY_DIR/private.pem"
  fi

  # Generate SSH keypair for relay connections
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ ! -f "$ssh_key" ]; then
    ssh-keygen -t ed25519 -f "$ssh_key" -N "" -C "agent-relay-${name}" -q
    # Authorize this key for incoming connections
    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    local pubkey
    pubkey=$(cat "${ssh_key}.pub")
    if ! grep -qF "$pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null; then
      echo "$pubkey" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
    fi
  fi

  # Write config
  cat > "$CONFIG" << EOF
{
  "name": "$name",
  "host": "$(get_host)",
  "created": "$(timestamp)"
}
EOF

  touch "$MESSAGES"

  # Share message log with primary instance for local multi-agent
  if [ "$RELAY_HOME" != "$PRIMARY_HOME" ] && [ -f "$PRIMARY_HOME/messages.jsonl" ]; then
    # Use the primary's message log so all local agents see each other
    rm -f "$MESSAGES"
    ln -sf "$PRIMARY_HOME/messages.jsonl" "$MESSAGES"
    # Copy peers from primary
    for f in "$PRIMARY_HOME/peers/"*.json "$PRIMARY_HOME/peers/"*.pub; do
      [ -f "$f" ] && cp "$f" "$PEERS_DIR/" 2>/dev/null
    done
    # Register as local peer of primary
    cat > "$PRIMARY_HOME/peers/${name}.json" << PEER
{
  "name": "$name",
  "host": "$(whoami)@$(get_host)",
  "paired": "$(timestamp)"
}
PEER
    cp "$IDENTITY_DIR/public.pem" "$PRIMARY_HOME/peers/${name}.pub" 2>/dev/null
    # Register primary as our peer
    local primary_name
    primary_name=$(python3 -c "import json; print(json.load(open('$PRIMARY_HOME/config.json'))['name'])" 2>/dev/null)
    cat > "$PEERS_DIR/${primary_name}.json" << PEER
{
  "name": "$primary_name",
  "host": "$(whoami)@$(get_host)",
  "paired": "$(timestamp)"
}
PEER
    cp "$PRIMARY_HOME/identity/public.pem" "$PEERS_DIR/${primary_name}.pub" 2>/dev/null
  fi

  local host
  host=$(get_host)
  local user
  user=$(whoami)

  echo ""
  echo "  Relay initialized as '$name'"
  if [ "$RELAY_HOME" != "$PRIMARY_HOME" ]; then
    echo "  (local session — sharing messages with primary instance)"
    echo ""
    echo "  Use with:  AGENT_RELAY_HOME=$RELAY_HOME relay send <peer> <msg>"
  else
    echo ""
    echo "  On the other machine, run:"
    echo ""
    echo "    relay join ${name}@${user}@${host}"
    echo ""
    echo "  Waiting for peer to join (listening on port 7547)..."
    # Start key-exchange listener — joiner sends its SSH pubkey, we reply with ours
    # This bootstraps SSH access without requiring pre-existing auth
    cmd_listen
  fi
  echo ""
}

cmd_join() {
  local target="${1:-}"
  [ -z "$target" ] && die "Usage: relay join <name@user@host>"

  local peer_name ssh_target
  peer_name="${target%%@*}"
  ssh_target="${target#*@}"
  local peer_host_only="${ssh_target##*@}"

  [ -z "$peer_name" ] || [ -z "$ssh_target" ] && die "Invalid target. Format: name@user@host"

  # Initialize ourselves if not already done
  if [ ! -f "$CONFIG" ]; then
    local my_name
    my_name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)
    cmd_start "$my_name"
  fi

  ensure_init
  mkdir -p "$PEERS_DIR"

  # Ensure we have an SSH key
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ ! -f "$ssh_key" ]; then
    ssh-keygen -t ed25519 -f "$ssh_key" -N "" -C "agent-relay-$(get_name)" -q
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    local pubkey; pubkey=$(cat "${ssh_key}.pub")
    grep -qF "$pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
      echo "$pubkey" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
    }
  fi

  echo "Connecting to $peer_host_only:$PAIR_PORT for key exchange..."

  # TCP key exchange — no SSH auth needed
  # Send our info, receive host's info
  local my_name my_host my_ssh_pub my_sign_pub
  my_name=$(get_name)
  my_host="$(whoami)@$(get_host)"
  my_ssh_pub=$(cat "$IDENTITY_DIR/ssh_key.pub" 2>/dev/null)
  my_sign_pub=$(cat "$IDENTITY_DIR/public.pem" 2>/dev/null)

  local response
  response=$(python3 -c "
import socket, json, sys

payload = json.dumps({
    'name': '$my_name',
    'host': '$my_host',
    'ssh_pub': '''$my_ssh_pub''',
    'sign_pub': '''$my_sign_pub'''
})

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(30)
try:
    sock.connect(('$peer_host_only', $PAIR_PORT))
    sock.sendall((payload + '\n').encode())
    sock.shutdown(socket.SHUT_WR)
    data = b''
    while True:
        chunk = sock.recv(4096)
        if not chunk: break
        data += chunk
    sock.close()
    host_info = json.loads(data.decode().strip())
    print(json.dumps(host_info))
except Exception as e:
    print(f'ERROR: {e}', file=sys.stderr)
    sys.exit(1)
" 2>/dev/null) || die "Can't reach $peer_host_only:$PAIR_PORT. Is 'relay start' running on the host?"

  # Parse host's response
  local host_ssh_pub host_sign_pub
  host_ssh_pub=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('ssh_pub',''))" 2>/dev/null)
  host_sign_pub=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('sign_pub',''))" 2>/dev/null)

  # Authorize host's SSH key locally (so host can send us messages via SSH)
  if [ -n "$host_ssh_pub" ]; then
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    grep -qF "$host_ssh_pub" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
      echo "$host_ssh_pub" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
    }
  fi

  # Save peer
  echo "$host_sign_pub" > "$PEERS_DIR/${peer_name}.pub"
  cat > "$PEERS_DIR/${peer_name}.json" << EOF
{
  "name": "$peer_name",
  "host": "$ssh_target",
  "paired": "$(timestamp)"
}
EOF

  echo ""
  echo "  Paired with '$peer_name'"
  echo ""
  echo "  Send a message:  relay send $peer_name 'hello'"
  echo "  Start monitor:   relay monitor"
  echo ""
}

cmd_send() {
  local peer_name="${1:-}"
  shift 2>/dev/null || true
  local msg="$*"
  [ -z "$peer_name" ] || [ -z "$msg" ] && die "Usage: relay send <peer> <message>"
  ensure_init

  local peer_file="$PEERS_DIR/${peer_name}.json"
  [ -f "$peer_file" ] || die "Unknown peer: $peer_name. Run: relay peers"

  local peer_host my_name ts
  peer_host=$(python3 -c "import json; print(json.load(open('$peer_file'))['host'])" 2>/dev/null)
  my_name=$(get_name)
  ts=$(timestamp)

  # Escape message for JSON
  local escaped_msg
  escaped_msg=$(printf '%s' "$msg" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")

  # Build + sign
  local payload="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\"}"
  local sig
  sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\",\"sig\":\"$sig\"}"

  # Detect if peer is local (same machine — messages.jsonl is shared/symlinked)
  local peer_hostname my_hostname is_local=false
  peer_hostname="${peer_host##*@}"
  my_hostname=$(hostname)
  [ "$peer_hostname" = "$my_hostname" ] && is_local=true
  [ "$peer_hostname" = "localhost" ] && is_local=true
  [ "$peer_hostname" = "$(get_host)" ] && is_local=true

  if [ "$is_local" = true ]; then
    # Local peer — shared messages file, write once only
    echo "$full_msg" >> "$MESSAGES"
  else
    # Remote peer — deliver via SSH, then log locally
    relay_ssh "$peer_host" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null \
      || die "Failed to deliver to $peer_host"
    echo "$full_msg" >> "$MESSAGES"
  fi
}

cmd_send_file() {
  local peer_name="${1:-}" filepath="${2:-}"
  [ -z "$peer_name" ] || [ -z "$filepath" ] && die "Usage: relay send-file <peer> <path>"
  [ -f "$filepath" ] || die "File not found: $filepath"
  ensure_init

  local peer_file="$PEERS_DIR/${peer_name}.json"
  [ -f "$peer_file" ] || die "Unknown peer: $peer_name. Run: relay peers"

  local peer_host my_name ts filename filesize
  peer_host=$(python3 -c "import json; print(json.load(open('$peer_file'))['host'])" 2>/dev/null)
  my_name=$(get_name)
  ts=$(timestamp)
  filename=$(basename "$filepath")
  filesize=$(stat -f%z "$filepath" 2>/dev/null || stat -c%s "$filepath" 2>/dev/null || echo "0")

  # Create files dir on peer
  relay_ssh "$peer_host" "mkdir -p ~/.agent-relay/files/${my_name}" 2>/dev/null

  # Transfer via scp
  relay_scp -q "$filepath" "${peer_host}:~/.agent-relay/files/${my_name}/${filename}" 2>/dev/null \
    || die "Failed to transfer $filename to $peer_host"

  # Notify peer via message
  local escaped_name
  escaped_name=$(printf '%s' "$filename" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")
  local payload="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"type\":\"file\",\"msg\":\"Sent file: $escaped_name ($filesize bytes)\",\"file\":{\"name\":\"$escaped_name\",\"size\":$filesize,\"path\":\"files/${my_name}/${escaped_name}\"}}"
  local sig
  sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"type\":\"file\",\"msg\":\"Sent file: $escaped_name ($filesize bytes)\",\"file\":{\"name\":\"$escaped_name\",\"size\":$filesize,\"path\":\"files/${my_name}/${escaped_name}\"},\"sig\":\"$sig\"}"

  # Detect if peer is local (same machine — messages.jsonl is shared/symlinked)
  local peer_hostname my_hostname is_local=false
  peer_hostname="${peer_host##*@}"
  my_hostname=$(hostname)
  [ "$peer_hostname" = "$my_hostname" ] && is_local=true
  [ "$peer_hostname" = "localhost" ] && is_local=true
  [ "$peer_hostname" = "$(get_host)" ] && is_local=true

  if [ "$is_local" = true ]; then
    echo "$full_msg" >> "$MESSAGES"
  else
    relay_ssh "$peer_host" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null
    echo "$full_msg" >> "$MESSAGES"
  fi

  echo "Sent $filename ($filesize bytes) to $peer_name"
}

cmd_monitor() {
  ensure_init
  local filter="${1:-}"
  local my_name
  my_name=$(get_name)

  local last
  last=$(wc -l < "$MESSAGES" 2>/dev/null || echo 0)
  while true; do
    local now
    now=$(wc -l < "$MESSAGES" 2>/dev/null || echo 0)
    if [ "$now" -gt "$last" ] 2>/dev/null; then
      local new_lines
      new_lines=$(sed -n "$(($last+1)),${now}p" "$MESSAGES")
      # Filter out own messages — only show incoming
      echo "$new_lines" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        local msg_from
        msg_from=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('from',''))" 2>/dev/null || true)
        [ "$msg_from" = "$my_name" ] && continue
        if [ -n "$filter" ]; then
          echo "$line" | grep --line-buffered "$filter" || true
        else
          echo "$line"
        fi
      done
      last=$now
    fi
    sleep 5
  done
}

cmd_peers() {
  ensure_init
  local found=false
  for f in "$PEERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    found=true
    local name host
    name=$(python3 -c "import json; print(json.load(open('$f'))['name'])" 2>/dev/null)
    host=$(python3 -c "import json; print(json.load(open('$f'))['host'])" 2>/dev/null)
    echo "  $name → $host"
  done
  [ "$found" = false ] && echo "  No peers. Run: relay join <name@user@host>"
}

cmd_pubkey() {
  ensure_init
  cat "$IDENTITY_DIR/public.pem"
}

cmd_logs() {
  ensure_init
  local count="${1:-20}"
  tail -"$count" "$MESSAGES" 2>/dev/null | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        m = json.loads(line.strip())
        print(f\"[{m.get('ts','')}] {m.get('from','?')}: {m.get('msg','')}\")
    except: pass
"
}

# ── Dispatch ────────────────────────────────────────────────────────────

case "${1:-help}" in
  start)     shift; cmd_start "$@" ;;
  join)      shift; cmd_join "$@" ;;
  send)      shift; cmd_send "$@" ;;
  send-file) shift; cmd_send_file "$@" ;;
  monitor)   shift; cmd_monitor "$@" ;;
  peers)     cmd_peers ;;
  pubkey)    cmd_pubkey ;;
  logs)      shift; cmd_logs "$@" ;;
  help|--help|-h)
    echo "Agent Relay — secure messaging between AI agent instances"
    echo ""
    echo "  relay start <name>             Initialize and show join command"
    echo "  relay join <name@user@host>    Pair with the other machine"
    echo "  relay send <peer> <message>    Send a signed message"
    echo "  relay send-file <peer> <path>  Send a file (diffs, patches, images)"
    echo "  relay monitor [filter]         Stream incoming (for agent monitors)"
    echo "  relay peers                    List paired machines"
    echo "  relay logs [count]             Show recent messages"
    echo "  relay pubkey                   Print your public key"
    ;;
  *) die "Unknown command: $1" ;;
esac
