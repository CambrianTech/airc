#!/bin/bash
# Agent Relay — secure messaging between AI agent instances.
# Requires Tailscale: https://tailscale.com
#
# relay connect              → host, wait for peers
# relay connect name@host    → join a host
# relay send peer "message"  → send a message

set -euo pipefail

RELAY_HOME="${AGENT_RELAY_HOME:-$HOME/.agent-relay}"
CONFIG="$RELAY_HOME/config.json"
IDENTITY_DIR="$RELAY_HOME/identity"
PEERS_DIR="$RELAY_HOME/peers"
MESSAGES="$RELAY_HOME/messages.jsonl"

# ── Helpers ─────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

ensure_init() {
  [ -f "$CONFIG" ] || die "Not initialized. Run: relay connect"
}

get_name() {
  python3 -c "import json; print(json.load(open('$CONFIG'))['name'])" 2>/dev/null || echo "unknown"
}

get_config_val() {
  python3 -c "import json; print(json.load(open('$CONFIG')).get('$1','$2'))" 2>/dev/null || echo "$2"
}

ts_bin() {
  if command -v tailscale >/dev/null 2>&1; then
    echo "tailscale"
  elif [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ]; then
    echo "/Applications/Tailscale.app/Contents/MacOS/Tailscale"
  else
    die "Tailscale is required. Install from https://tailscale.com"
  fi
}

get_host() {
  local ts; ts=$(ts_bin)
  $ts ip -4 2>/dev/null || die "Tailscale not connected. Run: tailscale up"
}

timestamp() { date -u +%Y-%m-%dT%H:%M:%SZ; }

sign_message() {
  local tmpfile; tmpfile=$(mktemp)
  printf '%s' "$1" > "$tmpfile"
  openssl pkeyutl -sign -inkey "$IDENTITY_DIR/private.pem" -in "$tmpfile" 2>/dev/null | base64
  rm -f "$tmpfile"
}

ts_ssh() {
  local ts; ts=$(ts_bin)
  $ts ssh -o StrictHostKeyChecking=accept-new "$@"
}

init_identity() {
  local name="$1"
  mkdir -p "$RELAY_HOME" "$IDENTITY_DIR" "$PEERS_DIR"
  if [ ! -f "$IDENTITY_DIR/private.pem" ]; then
    openssl genpkey -algorithm Ed25519 -out "$IDENTITY_DIR/private.pem" 2>/dev/null
    openssl pkey -in "$IDENTITY_DIR/private.pem" -pubout -out "$IDENTITY_DIR/public.pem" 2>/dev/null
    chmod 600 "$IDENTITY_DIR/private.pem"
  fi
  touch "$MESSAGES"
}

monitor() {
  local my_name host_target last=0
  my_name=$(get_name)
  host_target=$(get_config_val host_target "")

  while true; do
    local lines=""
    if [ -n "$host_target" ]; then
      lines=$(ts_ssh "$host_target" "tail -n +$((last+1)) ~/.agent-relay/messages.jsonl 2>/dev/null" 2>/dev/null) || true
    else
      lines=$(tail -n +$((last+1)) "$MESSAGES" 2>/dev/null) || true
    fi
    if [ -n "$lines" ]; then
      local count; count=$(echo "$lines" | wc -l)
      last=$((last + count))
      echo "$lines" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        local msg_from
        msg_from=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('from',''))" 2>/dev/null || true)
        [ "$msg_from" = "$my_name" ] && continue
        echo "$line"
      done
    fi
    sleep 5
  done
}

# ── Commands ────────────────────────────────────────────────────────────

cmd_connect() {
  local target="${1:-}"

  # Verify Tailscale
  local ts; ts=$(ts_bin)
  $ts ip -4 >/dev/null 2>&1 || die "Tailscale not connected. Run: tailscale up"

  if [ -n "$target" ] && echo "$target" | grep -q '@'; then
    # ── JOIN MODE ──────────────────────────────────────────────────
    local peer_name ssh_target
    peer_name="${target%%@*}"
    ssh_target="${target#*@}"

    [ -z "$peer_name" ] || [ -z "$ssh_target" ] && die "Format: relay connect name@user@host"

    local my_name
    my_name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)
    init_identity "$my_name"

    cat > "$CONFIG" << EOF
{
  "name": "$my_name",
  "host": "$(get_host)",
  "host_target": "$ssh_target",
  "created": "$(timestamp)"
}
EOF

    # Register with host via Tailscale SSH
    echo "  Connecting to $ssh_target..."
    local ssh_output
    ssh_output=$(ts_ssh "$ssh_target" "
      mkdir -p ~/.agent-relay/peers
      echo '{\"name\":\"${my_name}\",\"host\":\"$(whoami)@$(get_host)\",\"paired\":\"$(timestamp)\"}' > ~/.agent-relay/peers/${my_name}.json
      cat > ~/.agent-relay/peers/${my_name}.pub << SIGNKEY
$(cat "$IDENTITY_DIR/public.pem")
SIGNKEY
      echo 'OK'
    " 2>&1)

    if echo "$ssh_output" | grep -q 'OK'; then
      echo "  Connected to '$peer_name'"
      echo "  Monitoring for messages..."
      monitor
    else
      echo ""
      echo "  FAILED to connect to $ssh_target"
      echo "  $ssh_output"
      echo ""
      echo "  Make sure:"
      echo "    - Host is running 'relay connect'"
      echo "    - Both machines are on the same Tailscale network"
      echo "    - Tailscale SSH is enabled (tailscale up --ssh)"
      exit 1
    fi

  else
    # ── HOST MODE ─────────────────────────────────────────────────
    local name="${target:-}"
    [ -z "$name" ] && name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)

    init_identity "$name"

    cat > "$CONFIG" << EOF
{
  "name": "$name",
  "host": "$(get_host)",
  "created": "$(timestamp)"
}
EOF

    local host; host=$(get_host)
    local user; user=$(whoami)

    echo ""
    echo "  Hosting as '$name'"
    echo ""
    echo "  On the other machine:"
    echo "    relay connect ${name}@${user}@${host}"
    echo ""
    echo "  Monitoring for messages..."
    monitor
  fi
}

cmd_send() {
  local peer_name="${1:-}"
  shift 2>/dev/null || true
  local msg="$*"
  [ -z "$peer_name" ] || [ -z "$msg" ] && die "Usage: relay send <peer> <message>"
  ensure_init

  local my_name ts_val
  my_name=$(get_name)
  ts_val=$(timestamp)

  local escaped_msg
  escaped_msg=$(printf '%s' "$msg" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")

  local payload="{\"from\":\"$my_name\",\"to\":\"$peer_name\",\"ts\":\"$ts_val\",\"msg\":\"$escaped_msg\"}"
  local sig; sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"to\":\"$peer_name\",\"ts\":\"$ts_val\",\"msg\":\"$escaped_msg\",\"sig\":\"$sig\"}"

  local host_target
  host_target=$(get_config_val host_target "")

  if [ -n "$host_target" ]; then
    ts_ssh "$host_target" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null \
      || die "Failed to deliver to host ($host_target)"
  else
    echo "$full_msg" >> "$MESSAGES"
  fi
}

cmd_send_file() {
  local peer_name="${1:-}" filepath="${2:-}"
  [ -z "$peer_name" ] || [ -z "$filepath" ] && die "Usage: relay send-file <peer> <path>"
  [ -f "$filepath" ] || die "File not found: $filepath"
  ensure_init

  local host_target my_name
  host_target=$(get_config_val host_target "")
  my_name=$(get_name)

  local filename; filename=$(basename "$filepath")
  local target_host="$host_target"
  [ -z "$target_host" ] && target_host="localhost"

  ts_ssh "$target_host" "mkdir -p ~/.agent-relay/files/${my_name}" 2>/dev/null
  local ts; ts=$(ts_bin)
  $ts file cp "$filepath" "${target_host}:" 2>/dev/null \
    || die "Failed to transfer $filename"

  local filesize; filesize=$(stat -f%z "$filepath" 2>/dev/null || stat -c%s "$filepath" 2>/dev/null || echo "0")
  cmd_send "$peer_name" "Sent file: $filename ($filesize bytes)"
  echo "Sent $filename ($filesize bytes)"
}

cmd_peers() {
  ensure_init
  local found=false
  for f in "$PEERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    found=true
    local name host
    name=$(python3 -c "import json; print(json.load(open('$f'))['name'])" 2>/dev/null)
    host=$(python3 -c "import json; print(json.load(open('$f'))['host'])" 2>/dev/null)
    echo "  $name → $host"
  done
  [ "$found" = false ] && echo "  No peers yet."
}

cmd_logs() {
  ensure_init
  local count="${1:-20}"
  local host_target
  host_target=$(get_config_val host_target "")

  local raw
  if [ -n "$host_target" ]; then
    raw=$(ts_ssh "$host_target" "tail -${count} ~/.agent-relay/messages.jsonl 2>/dev/null" 2>/dev/null) || true
  else
    raw=$(tail -"$count" "$MESSAGES" 2>/dev/null) || true
  fi
  echo "$raw" | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        m = json.loads(line.strip())
        print(f\"[{m.get('ts','')}] {m.get('from','?')}: {m.get('msg','')}\")
    except: pass
"
}

# ── Dispatch ────────────────────────────────────────────────────────────

case "${1:-help}" in
  connect|setup|start|join) shift; cmd_connect "$@" ;;
  send)      shift; cmd_send "$@" ;;
  send-file) shift; cmd_send_file "$@" ;;
  peers)     cmd_peers ;;
  logs)      shift; cmd_logs "$@" ;;
  monitor)   shift; monitor "$@" ;;
  help|--help|-h)
    echo "Agent Relay — secure messaging between AI agents (requires Tailscale)"
    echo ""
    echo "  relay connect                    Host — wait for peers"
    echo "  relay connect <name@user@host>   Join a host"
    echo "  relay send <peer> <message>      Send a message"
    echo "  relay peers                      List connected peers"
    ;;
  *) die "Unknown command: $1. Try: relay help" ;;
esac
