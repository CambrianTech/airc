#!/bin/bash
# Agent Relay — secure peer-to-peer messaging between AI agent instances.
# Two commands to connect: `relay start <name>` on one machine, `relay join <name@host>` on the other.

set -euo pipefail

RELAY_HOME="${AGENT_RELAY_HOME:-$HOME/.agent-relay}"
CONFIG="$RELAY_HOME/config.json"
IDENTITY_DIR="$RELAY_HOME/identity"
PEERS_DIR="$RELAY_HOME/peers"
MESSAGES="$RELAY_HOME/messages.jsonl"

# ── Helpers ─────────────────────────────────────────────────────────────

die() { echo "ERROR: $*" >&2; exit 1; }

ensure_init() {
  [ -f "$CONFIG" ] || die "Not initialized. Run: relay start <name>"
  [ -f "$IDENTITY_DIR/private.pem" ] || die "No keypair. Run: relay start <name>"
}

get_name() {
  python3 -c "import json; print(json.load(open('$CONFIG'))['name'])" 2>/dev/null || echo "unknown"
}

get_host() {
  # Prefer Tailscale IP (always reachable across tailnet), fall back to local hostname
  local ts_bin=""
  if command -v tailscale >/dev/null 2>&1; then
    ts_bin="tailscale"
  elif [ -x "/Applications/Tailscale.app/Contents/MacOS/Tailscale" ]; then
    ts_bin="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
  fi
  if [ -n "$ts_bin" ]; then
    local ts_ip
    ts_ip=$("$ts_bin" ip -4 2>/dev/null || true)
    [ -n "$ts_ip" ] && echo "$ts_ip" && return
  fi
  hostname
}

timestamp() { date -u +%Y-%m-%dT%H:%M:%SZ; }

sign_message() {
  local tmpfile
  tmpfile=$(mktemp)
  printf '%s' "$1" > "$tmpfile"
  openssl pkeyutl -sign -inkey "$IDENTITY_DIR/private.pem" -in "$tmpfile" 2>/dev/null | base64
  rm -f "$tmpfile"
}

ensure_sshd() {
  # Check if port 22 is accepting connections AND sshd is actually working
  if nc -z localhost 22 2>/dev/null; then
    # Port open — but is sshd actually responding? (macOS ghost listener bug)
    if ssh -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new localhost "echo ok" 2>/dev/null; then
      return 0
    fi
    # Port open but handshake fails — ghost sshd. Restart it.
    echo "  SSH port 22 is open but not responding (ghost listener)."
    echo "  Restarting SSH daemon..."
    if [ "$(uname)" = "Darwin" ]; then
      sudo -n launchctl unload /System/Library/LaunchDaemons/ssh.plist 2>/dev/null
      sudo -n launchctl load -w /System/Library/LaunchDaemons/ssh.plist 2>/dev/null
      sleep 1
      if ssh -o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new localhost "echo ok" 2>/dev/null; then
        echo "  SSH daemon restarted."
        return 0
      fi
      # sudo failed — need user to toggle
      echo "  Could not restart automatically."
      echo "  Toggle Remote Login OFF then ON in System Settings."
      open "x-apple.systempreferences:com.apple.Sharing-Settings.extension" 2>/dev/null \
        || open "x-apple.systempreferences:com.apple.preference.sharing" 2>/dev/null \
        || true
      local attempts=0
      while ! ssh -o ConnectTimeout=2 -o StrictHostKeyChecking=accept-new localhost "echo ok" 2>/dev/null; do
        attempts=$((attempts + 1))
        [ "$attempts" -ge 30 ] && echo "  Timed out waiting for SSH." && return 1
        sleep 2
      done
      echo "  SSH is working!"
      return 0
    else
      sudo -n systemctl restart sshd 2>/dev/null && return 0
    fi
  fi

  echo "  SSH (Remote Login) is not running."
  if [ "$(uname)" = "Darwin" ]; then
    if sudo -n systemsetup -setremotelogin on 2>/dev/null; then
      echo "  Enabled Remote Login."
    else
      echo "  Opening System Settings — please enable Remote Login..."
      open "x-apple.systempreferences:com.apple.Sharing-Settings.extension" 2>/dev/null \
        || open "x-apple.systempreferences:com.apple.preference.sharing" 2>/dev/null \
        || echo "  → Open System Settings > General > Sharing > Remote Login"
      # Wait for user to enable it
      local attempts=0
      while ! nc -z localhost 22 2>/dev/null; do
        attempts=$((attempts + 1))
        [ "$attempts" -ge 30 ] && echo "  Timed out waiting for Remote Login." && return 1
        sleep 2
      done
      echo "  Remote Login enabled!"
    fi
  else
    if sudo -n systemctl start sshd 2>/dev/null || sudo -n service ssh start 2>/dev/null; then
      echo "  Started sshd."
    else
      echo "  Run: sudo systemctl start sshd"
      return 1
    fi
  fi
}

relay_ssh() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    ssh -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    ssh -o StrictHostKeyChecking=accept-new "$@"
  fi
}

relay_scp() {
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ -f "$ssh_key" ]; then
    scp -i "$ssh_key" -o StrictHostKeyChecking=accept-new "$@"
  else
    scp -o StrictHostKeyChecking=accept-new "$@"
  fi
}

# ── Commands ────────────────────────────────────────────────────────────

cmd_start() {
  local name="${1:-}"
  [ -z "$name" ] && die "Usage: relay start <your-name>"

  local PRIMARY_HOME="$HOME/.agent-relay"

  # If primary already exists with this name, auto-increment for a new session
  if [ -f "$PRIMARY_HOME/config.json" ]; then
    local existing_name
    existing_name=$(python3 -c "import json; print(json.load(open('$PRIMARY_HOME/config.json'))['name'])" 2>/dev/null)
    if [ "$existing_name" = "$name" ] || echo "$existing_name" | grep -qE "^${name}(-[0-9]+)?$"; then
      local n=1
      while [ -d "$HOME/.agent-relay-${name}-${n}" ]; do
        n=$((n + 1))
      done
      name="${name}-${n}"
      RELAY_HOME="$HOME/.agent-relay-${name}"
      CONFIG="$RELAY_HOME/config.json"
      IDENTITY_DIR="$RELAY_HOME/identity"
      PEERS_DIR="$RELAY_HOME/peers"
      MESSAGES="$RELAY_HOME/messages.jsonl"
    fi
  fi

  mkdir -p "$RELAY_HOME" "$IDENTITY_DIR" "$PEERS_DIR"
  ensure_sshd

  # Generate Ed25519 signing keypair
  if [ ! -f "$IDENTITY_DIR/private.pem" ]; then
    openssl genpkey -algorithm Ed25519 -out "$IDENTITY_DIR/private.pem" 2>/dev/null
    openssl pkey -in "$IDENTITY_DIR/private.pem" -pubout -out "$IDENTITY_DIR/public.pem" 2>/dev/null
    chmod 600 "$IDENTITY_DIR/private.pem"
  fi

  # Generate SSH keypair
  local ssh_key="$IDENTITY_DIR/ssh_key"
  if [ ! -f "$ssh_key" ]; then
    ssh-keygen -t ed25519 -f "$ssh_key" -N "" -C "agent-relay-${name}" -q
    mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
    local pubkey
    pubkey=$(cat "${ssh_key}.pub")
    if ! grep -qF "$pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null; then
      echo "$pubkey" >> "$HOME/.ssh/authorized_keys"
      chmod 600 "$HOME/.ssh/authorized_keys"
    fi
  fi

  # Write config
  cat > "$CONFIG" << EOF
{
  "name": "$name",
  "host": "$(get_host)",
  "created": "$(timestamp)"
}
EOF

  touch "$MESSAGES"

  # Share message log with primary instance for local multi-agent
  if [ "$RELAY_HOME" != "$PRIMARY_HOME" ] && [ -f "$PRIMARY_HOME/messages.jsonl" ]; then
    rm -f "$MESSAGES"
    ln -sf "$PRIMARY_HOME/messages.jsonl" "$MESSAGES"
    for f in "$PRIMARY_HOME/peers/"*.json "$PRIMARY_HOME/peers/"*.pub; do
      [ -f "$f" ] && cp "$f" "$PEERS_DIR/" 2>/dev/null
    done
    cat > "$PRIMARY_HOME/peers/${name}.json" << PEER
{
  "name": "$name",
  "host": "$(whoami)@$(get_host)",
  "paired": "$(timestamp)"
}
PEER
    cp "$IDENTITY_DIR/public.pem" "$PRIMARY_HOME/peers/${name}.pub" 2>/dev/null
    local primary_name
    primary_name=$(python3 -c "import json; print(json.load(open('$PRIMARY_HOME/config.json'))['name'])" 2>/dev/null)
    cat > "$PEERS_DIR/${primary_name}.json" << PEER
{
  "name": "$primary_name",
  "host": "$(whoami)@$(get_host)",
  "paired": "$(timestamp)"
}
PEER
    cp "$PRIMARY_HOME/identity/public.pem" "$PEERS_DIR/${primary_name}.pub" 2>/dev/null
  fi

  local host user
  host=$(get_host)
  user=$(whoami)

  # Encode SSH public key into join string
  local ssh_pubkey_b64
  ssh_pubkey_b64=$(base64 < "${IDENTITY_DIR}/ssh_key.pub" | tr -d '\n')

  echo ""
  echo "  Relay initialized as '$name'"
  if [ "$RELAY_HOME" != "$PRIMARY_HOME" ]; then
    echo "  (local session — sharing messages with primary instance)"
    echo ""
    echo "  Use with:  AGENT_RELAY_HOME=$RELAY_HOME relay send <peer> <msg>"
  else
    echo ""
    echo "  On the other machine, run:"
    echo ""
    echo "    relay join ${name}@${user}@${host}#${ssh_pubkey_b64}"
  fi
  echo ""
}

cmd_join() {
  local target="${1:-}"
  [ -z "$target" ] && die "Usage: relay join <name@user@host#pubkey>"

  # Parse name@user@host#base64-ssh-pubkey
  local host_ssh_pubkey_b64=""
  if echo "$target" | grep -q '#'; then
    host_ssh_pubkey_b64="${target##*#}"
    target="${target%%#*}"
  fi

  local peer_name ssh_target
  peer_name="${target%%@*}"
  ssh_target="${target#*@}"

  [ -z "$peer_name" ] || [ -z "$ssh_target" ] && die "Invalid target. Format: name@user@host#pubkey"

  # Initialize if needed (non-interactive)
  if [ ! -f "$CONFIG" ]; then
    local my_name
    my_name=$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)
    # Inline init — no listener, no blocking
    mkdir -p "$RELAY_HOME" "$IDENTITY_DIR" "$PEERS_DIR"
    ensure_sshd
    if [ ! -f "$IDENTITY_DIR/private.pem" ]; then
      openssl genpkey -algorithm Ed25519 -out "$IDENTITY_DIR/private.pem" 2>/dev/null
      openssl pkey -in "$IDENTITY_DIR/private.pem" -pubout -out "$IDENTITY_DIR/public.pem" 2>/dev/null
      chmod 600 "$IDENTITY_DIR/private.pem"
    fi
    local ssh_key="$IDENTITY_DIR/ssh_key"
    if [ ! -f "$ssh_key" ]; then
      ssh-keygen -t ed25519 -f "$ssh_key" -N "" -C "agent-relay-${my_name}" -q
      mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
      local pubkey; pubkey=$(cat "${ssh_key}.pub")
      grep -qF "$pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
        echo "$pubkey" >> "$HOME/.ssh/authorized_keys"
        chmod 600 "$HOME/.ssh/authorized_keys"
      }
    fi
    cat > "$CONFIG" << EOF
{
  "name": "$my_name",
  "host": "$(get_host)",
  "created": "$(timestamp)"
}
EOF
    touch "$MESSAGES"
    echo "  Initialized as '$my_name'"
  fi

  ensure_init
  ensure_sshd

  # Authorize host's SSH public key locally (so host can send us messages)
  if [ -n "$host_ssh_pubkey_b64" ]; then
    local host_ssh_pubkey
    host_ssh_pubkey=$(echo "$host_ssh_pubkey_b64" | base64 -d 2>/dev/null || echo "$host_ssh_pubkey_b64" | base64 -D 2>/dev/null || true)
    if [ -n "$host_ssh_pubkey" ]; then
      mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
      grep -qF "$host_ssh_pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
        echo "$host_ssh_pubkey" >> "$HOME/.ssh/authorized_keys"
        chmod 600 "$HOME/.ssh/authorized_keys"
      }
      echo "  Authorized host's SSH key"
    fi
  fi

  # Try SSH to host to complete bidirectional key exchange
  echo "  Connecting to $ssh_target..."
  local my_name my_host
  my_name=$(get_name)
  my_host="$(whoami)@$(get_host)"

  # One SSH session: push our key, grab their keys, register peer, test reverse
  local exchange_result
  exchange_result=$(relay_ssh "$ssh_target" "
    # 1. Authorize joiner's SSH key
    mkdir -p ~/.ssh && chmod 700 ~/.ssh
    KEY='$(cat "$IDENTITY_DIR/ssh_key.pub")'
    grep -qF \"\$KEY\" ~/.ssh/authorized_keys 2>/dev/null || echo \"\$KEY\" >> ~/.ssh/authorized_keys
    chmod 600 ~/.ssh/authorized_keys

    # 2. Register joiner as peer
    mkdir -p ~/.agent-relay/peers
    cat > ~/.agent-relay/peers/${my_name}.json << PEER
{\"name\":\"${my_name}\",\"host\":\"${my_host}\",\"paired\":\"$(timestamp)\"}
PEER
    cat > ~/.agent-relay/peers/${my_name}.pub << SIGNKEY
$(cat "$IDENTITY_DIR/public.pem")
SIGNKEY

    # 3. Output host's keys for joiner to save
    echo \"SSH_PUB:\$(cat ~/.agent-relay/identity/ssh_key.pub 2>/dev/null)\"
    echo \"SIGN_PUB_START\"
    cat ~/.agent-relay/identity/public.pem 2>/dev/null
    echo \"SIGN_PUB_END\"

    # 4. Test reverse: SSH back to joiner
    if ssh -i ~/.agent-relay/identity/ssh_key -o StrictHostKeyChecking=accept-new -o ConnectTimeout=5 ${my_host} 'echo ok' 2>/dev/null; then
      echo 'REVERSE:OK'
    else
      echo 'REVERSE:FAIL'
    fi
  " 2>/dev/null)

  if [ -n "$exchange_result" ]; then
    # Parse host's SSH pubkey
    local remote_ssh_pubkey
    remote_ssh_pubkey=$(echo "$exchange_result" | grep '^SSH_PUB:' | sed 's/^SSH_PUB://')
    if [ -n "$remote_ssh_pubkey" ]; then
      grep -qF "$remote_ssh_pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
        echo "$remote_ssh_pubkey" >> "$HOME/.ssh/authorized_keys"
      }
    fi

    # Parse host's signing pubkey
    local remote_pubkey
    remote_pubkey=$(echo "$exchange_result" | sed -n '/^SIGN_PUB_START$/,/^SIGN_PUB_END$/p' | grep -v 'SIGN_PUB_')

    # Save peer
    mkdir -p "$PEERS_DIR"
    [ -n "$remote_pubkey" ] && echo "$remote_pubkey" > "$PEERS_DIR/${peer_name}.pub"
    cat > "$PEERS_DIR/${peer_name}.json" << EOF
{
  "name": "$peer_name",
  "host": "$ssh_target",
  "paired": "$(timestamp)"
}
EOF

    # Check reverse result
    if echo "$exchange_result" | grep -q 'REVERSE:OK'; then
      echo "  Paired with '$peer_name' (bidirectional)"
    else
      echo "  Paired with '$peer_name' (one-way: you→host works, host→you FAILED)"
      echo ""
      echo "  Remote Login (SSH) needs to be enabled on THIS machine."
      if [ "$(uname)" = "Darwin" ]; then
        echo "  Trying to enable it..."
        if sudo -n systemsetup -setremotelogin on 2>/dev/null; then
          echo "  Enabled! Retry: relay join $1"
        else
          echo "  Need manual step — opening System Settings..."
          open "x-apple.systempreferences:com.apple.Sharing-Settings.extension" 2>/dev/null \
            || open "x-apple.systempreferences:com.apple.preference.sharing" 2>/dev/null \
            || true
          echo "  → Turn on 'Remote Login' then retry: relay join $1"
        fi
      else
        echo "  Run: sudo systemctl start sshd"
      fi
    fi
    echo ""
    echo "  Starting monitor..."
    cmd_monitor &
  else
    # SSH failed — save what we can, tell user how to complete
    mkdir -p "$PEERS_DIR"
    cat > "$PEERS_DIR/${peer_name}.json" << EOF
{
  "name": "$peer_name",
  "host": "$ssh_target",
  "paired": "$(timestamp)"
}
EOF

    local my_ssh_pubkey_b64
    my_ssh_pubkey_b64=$(base64 < "$IDENTITY_DIR/ssh_key.pub" | tr -d '\n')

    echo ""
    echo "  Partially paired with '$peer_name'"
    echo "  Host can send to you, but you can't send to host yet."
    echo ""
    echo "  To complete pairing, have the host run:"
    echo ""
    echo "    relay accept ${my_name}@${my_host}#${my_ssh_pubkey_b64}"
    echo ""
    echo "  Starting monitor..."
    cmd_monitor &
  fi
}

cmd_accept() {
  local target="${1:-}"
  [ -z "$target" ] && die "Usage: relay accept <name@user@host#pubkey>"
  ensure_init

  # Parse name@user@host#base64-ssh-pubkey
  local peer_ssh_pubkey_b64=""
  if echo "$target" | grep -q '#'; then
    peer_ssh_pubkey_b64="${target##*#}"
    target="${target%%#*}"
  fi

  local peer_name ssh_target
  peer_name="${target%%@*}"
  ssh_target="${target#*@}"

  [ -z "$peer_name" ] || [ -z "$ssh_target" ] && die "Invalid target. Format: name@user@host#pubkey"

  # Authorize peer's SSH public key
  if [ -n "$peer_ssh_pubkey_b64" ]; then
    local peer_ssh_pubkey
    peer_ssh_pubkey=$(echo "$peer_ssh_pubkey_b64" | base64 -d 2>/dev/null || echo "$peer_ssh_pubkey_b64" | base64 -D 2>/dev/null || true)
    if [ -n "$peer_ssh_pubkey" ]; then
      mkdir -p "$HOME/.ssh" && chmod 700 "$HOME/.ssh"
      grep -qF "$peer_ssh_pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null || {
        echo "$peer_ssh_pubkey" >> "$HOME/.ssh/authorized_keys"
        chmod 600 "$HOME/.ssh/authorized_keys"
      }
    fi
  fi

  # Save peer
  mkdir -p "$PEERS_DIR"
  cat > "$PEERS_DIR/${peer_name}.json" << EOF
{
  "name": "$peer_name",
  "host": "$ssh_target",
  "paired": "$(timestamp)"
}
EOF

  # Try to fetch signing key via SSH
  local remote_pubkey
  remote_pubkey=$(relay_ssh "$ssh_target" "cat ~/.agent-relay/identity/public.pem" 2>/dev/null) || true
  [ -n "$remote_pubkey" ] && echo "$remote_pubkey" > "$PEERS_DIR/${peer_name}.pub"

  echo ""
  echo "  Accepted '$peer_name' ($ssh_target)"
  echo ""
}

cmd_send() {
  local peer_name="${1:-}"
  shift 2>/dev/null || true
  local msg="$*"
  [ -z "$peer_name" ] || [ -z "$msg" ] && die "Usage: relay send <peer> <message>"
  ensure_init

  local peer_file="$PEERS_DIR/${peer_name}.json"
  [ -f "$peer_file" ] || die "Unknown peer: $peer_name. Run: relay peers"

  local peer_host my_name ts
  peer_host=$(python3 -c "import json; print(json.load(open('$peer_file'))['host'])" 2>/dev/null)
  my_name=$(get_name)
  ts=$(timestamp)

  local escaped_msg
  escaped_msg=$(printf '%s' "$msg" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")

  local payload="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\"}"
  local sig
  sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"msg\":\"$escaped_msg\",\"sig\":\"$sig\"}"

  # Detect local peer
  local peer_hostname my_hostname is_local=false
  peer_hostname="${peer_host##*@}"
  my_hostname=$(hostname)
  [ "$peer_hostname" = "$my_hostname" ] && is_local=true
  [ "$peer_hostname" = "localhost" ] && is_local=true
  [ "$peer_hostname" = "$(get_host)" ] && is_local=true

  if [ "$is_local" = true ]; then
    echo "$full_msg" >> "$MESSAGES"
  else
    relay_ssh "$peer_host" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null \
      || die "Failed to deliver to $peer_host"
    echo "$full_msg" >> "$MESSAGES"
  fi
}

cmd_send_file() {
  local peer_name="${1:-}" filepath="${2:-}"
  [ -z "$peer_name" ] || [ -z "$filepath" ] && die "Usage: relay send-file <peer> <path>"
  [ -f "$filepath" ] || die "File not found: $filepath"
  ensure_init

  local peer_file="$PEERS_DIR/${peer_name}.json"
  [ -f "$peer_file" ] || die "Unknown peer: $peer_name. Run: relay peers"

  local peer_host my_name ts filename filesize
  peer_host=$(python3 -c "import json; print(json.load(open('$peer_file'))['host'])" 2>/dev/null)
  my_name=$(get_name)
  ts=$(timestamp)
  filename=$(basename "$filepath")
  filesize=$(stat -f%z "$filepath" 2>/dev/null || stat -c%s "$filepath" 2>/dev/null || echo "0")

  relay_ssh "$peer_host" "mkdir -p ~/.agent-relay/files/${my_name}" 2>/dev/null
  relay_scp -q "$filepath" "${peer_host}:~/.agent-relay/files/${my_name}/${filename}" 2>/dev/null \
    || die "Failed to transfer $filename to $peer_host"

  local escaped_name
  escaped_name=$(printf '%s' "$filename" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")
  local payload="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"type\":\"file\",\"msg\":\"Sent file: $escaped_name ($filesize bytes)\",\"file\":{\"name\":\"$escaped_name\",\"size\":$filesize,\"path\":\"files/${my_name}/${escaped_name}\"}}"
  local sig
  sig=$(sign_message "$payload")
  local full_msg="{\"from\":\"$my_name\",\"ts\":\"$ts\",\"type\":\"file\",\"msg\":\"Sent file: $escaped_name ($filesize bytes)\",\"file\":{\"name\":\"$escaped_name\",\"size\":$filesize,\"path\":\"files/${my_name}/${escaped_name}\"},\"sig\":\"$sig\"}"

  local peer_hostname my_hostname is_local=false
  peer_hostname="${peer_host##*@}"
  my_hostname=$(hostname)
  [ "$peer_hostname" = "$my_hostname" ] && is_local=true
  [ "$peer_hostname" = "localhost" ] && is_local=true
  [ "$peer_hostname" = "$(get_host)" ] && is_local=true

  if [ "$is_local" = true ]; then
    echo "$full_msg" >> "$MESSAGES"
  else
    relay_ssh "$peer_host" "echo '$full_msg' >> ~/.agent-relay/messages.jsonl" 2>/dev/null
    echo "$full_msg" >> "$MESSAGES"
  fi

  echo "Sent $filename ($filesize bytes) to $peer_name"
}

cmd_monitor() {
  ensure_init
  local filter="${1:-}"
  local my_name
  my_name=$(get_name)

  local last
  last=$(wc -l < "$MESSAGES" 2>/dev/null || echo 0)
  while true; do
    local now
    now=$(wc -l < "$MESSAGES" 2>/dev/null || echo 0)
    if [ "$now" -gt "$last" ] 2>/dev/null; then
      local new_lines
      new_lines=$(sed -n "$(($last+1)),${now}p" "$MESSAGES")
      echo "$new_lines" | while IFS= read -r line; do
        [ -z "$line" ] && continue
        local msg_from
        msg_from=$(echo "$line" | python3 -c "import sys,json; print(json.loads(sys.stdin.read()).get('from',''))" 2>/dev/null || true)
        [ "$msg_from" = "$my_name" ] && continue
        if [ -n "$filter" ]; then
          echo "$line" | grep --line-buffered "$filter" || true
        else
          echo "$line"
        fi
      done
      last=$now
    fi
    sleep 5
  done
}

cmd_peers() {
  ensure_init
  local found=false
  for f in "$PEERS_DIR"/*.json; do
    [ -f "$f" ] || continue
    found=true
    local name host
    name=$(python3 -c "import json; print(json.load(open('$f'))['name'])" 2>/dev/null)
    host=$(python3 -c "import json; print(json.load(open('$f'))['host'])" 2>/dev/null)
    echo "  $name → $host"
  done
  [ "$found" = false ] && echo "  No peers. Run: relay join <name@user@host>"
}

cmd_pubkey() {
  ensure_init
  cat "$IDENTITY_DIR/public.pem"
}

cmd_logs() {
  ensure_init
  local count="${1:-20}"
  tail -"$count" "$MESSAGES" 2>/dev/null | python3 -c "
import sys, json
for line in sys.stdin:
    try:
        m = json.loads(line.strip())
        print(f\"[{m.get('ts','')}] {m.get('from','?')}: {m.get('msg','')}\")
    except: pass
"
}

cmd_setup() {
  # All-in-one: if arg has @, join. Otherwise, start.
  local target="${1:-}"
  if [ -n "$target" ] && echo "$target" | grep -q '@'; then
    cmd_join "$target"
  else
    cmd_start "${target:-$(hostname | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | cut -c1-16)}"
  fi
}

# ── Dispatch ────────────────────────────────────────────────────────────

case "${1:-help}" in
  setup)     shift; cmd_setup "$@" ;;
  start)     shift; cmd_start "$@" ;;
  join)      shift; cmd_join "$@" ;;
  accept)    shift; cmd_accept "$@" ;;
  send)      shift; cmd_send "$@" ;;
  send-file) shift; cmd_send_file "$@" ;;
  monitor)   shift; cmd_monitor "$@" ;;
  peers)     cmd_peers ;;
  pubkey)    cmd_pubkey ;;
  logs)      shift; cmd_logs "$@" ;;
  help|--help|-h)
    echo "Agent Relay — secure messaging between AI agent instances"
    echo ""
    echo "  relay setup                      Initialize this machine as host"
    echo "  relay setup <name@user@host#key> Join another machine"
    echo "  relay send <peer> <message>      Send a message"
    echo "  relay send-file <peer> <path>    Send a file"
    echo "  relay peers                      List paired machines"
    echo "  relay logs [count]               Show recent messages"
    echo ""
    echo "  Monitor starts automatically after setup."
    ;;
  *) die "Unknown command: $1" ;;
esac
